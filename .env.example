# At least the Anthropic key is required (the subject runs on Opus 4.7
# by default). The auditor can run on any of the three providers; default
# is anthropic.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Auditor provider (anthropic | openai | gemini). Default: anthropic.
AUDITOR_PROVIDER=anthropic

# Which test to run (see TESTS.md).
CASE_ID=manifest-qa-green

# Optional model overrides.
# ANTHROPIC_MODEL=claude-opus-4-7
# SUBJECT_MODEL=claude-opus-4-7
# OPENAI_MODEL=gpt-5.4
# GEMINI_MODEL=gemini-3.5-flash
